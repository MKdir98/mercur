# ============================================================================
# Demo Configuration - Minimal (تنظیمات حداقلی)
# ============================================================================
# کپی: cp demo-minimal.properties.example my-demo.properties
# دیپلوی: sudo bash deploy.sh my-demo.properties deploy
# ============================================================================

# Mode & Paths
MODE=demo
DEPLOY_DIR=/var/www/marketplace-demo

# GitHub
GITHUB_USERNAME=mkdir98
STOREFRONT_REPO=b2c-marketplace-storefront
BACKEND_REPO=mercur
VENDOR_REPO=vendor-panel

# Ports (باید با production متفاوت باشند)
STOREFRONT_PORT=3001
BACKEND_PORT=9001
VENDOR_PORT=5174

# Domains (DNS باید قبل از SSL آماده باشه)
STOREFRONT_DOMAIN=demo.doorfestival.com
BACKEND_DOMAIN=demo-core.doorfestival.com
VENDOR_DOMAIN=demo-brand.doorfestival.com

# Database (⚠️ پسورد رو عوض کن!)
DB_NAME=mercur_demo
DB_USER=mercuruser_demo
DB_PASSWORD=CHANGE_ME_secure_password_123

# Redis
REDIS_URL=redis://localhost:6379

# Site Info
DEFAULT_REGION=us
SITE_NAME=Marketplace Demo
SITE_DESCRIPTION=Demo environment

# Stripe (⚠️ از test keys استفاده کن)
STRIPE_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# Medusa
MEDUSA_PUBLISHABLE_KEY=pk_demo_XXXXXXXXXXXXXXXXXX
REVALIDATE_SECRET=CHANGE_ME_random_string_456

# Resend Email
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=noreply-demo@doorfestival.com

# Algolia Search
ALGOLIA_APP_ID=XXXXXXXXXX
ALGOLIA_SEARCH_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ALGOLIA_ADMIN_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# TalkJS Chat
TALKJS_APP_ID=tXXXXXXXX
TALKJS_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX

# SMS.ir (برای ایران)
SMS_IR_API_KEY=CHANGE_ME_sms_ir_key
SMS_IR_LINE_NUMBER=2
SMS_IR_TEMPLATE_ID=552147
SMS_IR_SANDBOX_API_KEY=sandbox_key
SMS_IR_SANDBOX_LINE_NUMBER=sandbox_line

# Feature Flags
DISABLE_SELLERS_REGISTRATION=false

# Storefront: show prices in USD (NEXT_PUBLIC_DISPLAY_PRICES_IN_USD on storefront; toman_per_usd from admin store metadata)
# DISPLAY_PRICES_IN_USD=false
# NEXT_PUBLIC_DISPLAY_PRICES_IN_USD=false

# Backend: fixed shipping in Rial for Postex option — skips Postex rate + parcel APIs (empty = use real Postex)
# POSTEX_FLAT_SHIPPING_AMOUNT_RIAL=

# Backend: Remitation (international card via Stripe/Mollie) instead of Zarinpal when true
# USE_REMITATION_PAYMENT_GATEWAY=false
# REMITATION_HTTP_PROXY=http://localhost:2080
# REMITATION_ACCESS_KEY=
# REMITATION_SECRET_KEY=
# REMITATION_API_BASE_URL=https://api.merchant.remitation.com/api
# REMITATION_PAYMENT_PROVIDER=stripe
# REMITATION_PAYMENT_CURRENCY=USD
# REMITATION_RIAL_PER_USD=
# Remitation: no sandbox env; test links come from test merchant / Stripe test mode in Remitation

# Storefront auth: phone | email (must match storefront NEXT_PUBLIC_AUTH_REGISTRATION_CHANNEL)
AUTH_REGISTRATION_CHANNEL=phone

# GET /store/payment-providers: log filtered provider ids (backend)
# LOG_PAYMENT_PROVIDERS=true
# LOG_PAYMENT_REGION=true
# SKIP_PAYMENT_PROVIDER_GATEWAY_FILTER=true

# Backend: Medusa region id (reg_...) forced on all store carts; clients cannot use another region for pricing/tax/checkout
# STORE_LOCKED_REGION_ID=
# ISO-2 comma list: allow shipping to these countries even if not linked to the cart region (e.g. NonIran cart + ir address)
# STORE_EXTRA_SHIPPING_COUNTRY_CODES=ir
# LOG_CROSS_REGION_CART=true

# OTP email (when AUTH_REGISTRATION_CHANNEL=email)
# OTP_EMAIL_PROVIDER=resend
# OTP_EMAIL_PROVIDER=smtp
OTP_EMAIL_FROM=noreply@example.com
OTP_EMAIL_SUBJECT=Your verification code
# OTP_EMAIL_DEBUG=true
# RESEND_API_KEY=re_xxxx
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=user
# SMTP_PASSWORD=secret


